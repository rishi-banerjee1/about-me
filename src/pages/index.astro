---
import { getCollection } from "astro:content";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  SITE,
  education,
  experience,
  expertise,
  heroStats,
  organizations,
  supportingSections,
  withBase,
  testimonials
} from "../lib/site";

const featuredProjects = (await getCollection("projects"))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.name,
  jobTitle: "Director of Talent Acquisition",
  description: SITE.description,
  worksFor: {
    "@type": "Organization",
    name: "Atlan",
    url: SITE.company
  },
  url: withBase("/"),
  image: new URL("/assets/headshot.jpg", SITE.site).toString(),
  sameAs: [SITE.linkedin, SITE.github],
  alumniOf: {
    "@type": "EducationalOrganization",
    name: "IIM Nagpur"
  },
  knowsAbout: [
    "Talent Acquisition",
    "AI systems",
    "Prompt governance",
    "Evaluation frameworks",
    "Hiring systems"
  ]
};
---
<BaseLayout
  title="Rishi Banerjee - TA Leader Who Builds Systems"
  description={SITE.description}
  jsonLd={jsonLd}
>
  <Nav />

  <main>
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-copy" data-reveal>
          <p class="eyebrow">Talent systems, AI products, and hiring doctrine encoded in software</p>
          <h1>{SITE.name}</h1>
          <p class="hero-text">
            I lead Global R&amp;D Talent Strategy &amp; Acquisition at <a href={SITE.company} target="_blank" rel="noopener">Atlan</a>.
            I build high-performing teams, and I also build the systems that make hiring more rigorous, repeatable,
            and useful at scale.
          </p>
          <p class="hero-text hero-text-muted">
            The strongest pattern across my GitHub is simple: turn fuzzy judgment into durable operating systems.
            That shows up in prompt governance, talent evaluation, offer experiences, agentic triage, and open source tooling.
          </p>
          <div class="button-row">
            <a href={SITE.linkedin} class="button button-primary" target="_blank" rel="noopener">LinkedIn</a>
            <a href={SITE.promptControlPlane} class="button button-secondary" target="_blank" rel="noopener">Prompt Control Plane</a>
            <a href={SITE.github} class="button button-secondary" target="_blank" rel="noopener">GitHub</a>
          </div>
          <div class="stats-grid">
            {heroStats.map((stat) => (
              <div class="stat-card">
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="hero-aside" data-reveal>
          <img src={withBase("/assets/headshot.jpg")} alt="Rishi Banerjee" class="hero-photo" />
          <div class="hero-note">
            <p class="hero-note-title">Current through GitHub review</p>
            <p>
              Reviewed across public and private repos on March 12, 2026. The flagship narrative now reflects the
              actual account, not just the older public pages.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="logo-section" data-reveal>
      <div class="container">
        <p class="eyebrow">Organizations I have helped scale</p>
        <div class="logo-row">
          {organizations.map((org) => (
            <a href={org.href} class="logo-link">
              <img
                src={withBase(org.logo)}
                alt={org.name}
                class:list={["logo-image", org.invertInDark && "logo-image-invert"]}
              />
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="about" class="section section-alt" data-reveal>
      <div class="container prose-block">
        <p class="eyebrow">About</p>
        <h2>AI-native TA leader who builds systems</h2>
        <p>
          As Director of Talent Acquisition at Atlan, I own Global R&amp;D Talent Strategy &amp; Acquisition across
          Engineering, Product, Design, IT, and Security. Over 20+ years, I have built and scaled TA functions across APAC,
          North America, and Europe.
        </p>
        <p>
          What makes the body of work unusual is that I also build the products that support the work: talent operating
          systems, interview evaluators, private offer experiences, prompt governance, usage observability, and agentic
          inbox triage. Some are public products, some are private internal systems, but they all come from the same instinct:
          if a judgment process matters, it deserves a better operating system.
        </p>
      </div>
    </section>

    <section id="projects" class="section" data-reveal>
      <div class="container">
        <div class="section-intro">
          <div>
            <p class="eyebrow">Flagship Projects</p>
            <h2>What I would lead with today</h2>
          </div>
          <a href={withBase("/projects/")} class="text-link">View all projects</a>
        </div>
        <div class="project-grid">
          {featuredProjects.map((project) => (
            <ProjectCard
              project={{
                title: project.data.title,
                shortSummary: project.data.shortSummary,
                summary: project.data.summary,
                tags: project.data.tags,
                visibility: project.data.visibility,
                status: project.data.status
              }}
              href={withBase(`/projects/${project.slug}/`)}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="section section-alt" data-reveal>
      <div class="container">
        <div class="section-intro">
          <div>
            <p class="eyebrow">GitHub View</p>
            <h2>The rest of the account, organized</h2>
          </div>
          <p class="section-note">
            22 repos reviewed across public and private work. The main signal is stronger than the raw repo count:
            talent systems, AI operators, and durable workflow tooling.
          </p>
        </div>
        {supportingSections.map((section) => (
          <div class="stack-block">
            <div class="stack-intro">
              <h3>{section.title}</h3>
              <p>{section.description}</p>
            </div>
            <div class="project-grid project-grid-compact">
              {section.projects.map((project) => (
                <ProjectCard project={project} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="experience" class="section" data-reveal>
      <div class="container">
        <p class="eyebrow">Experience</p>
        <h2>Career</h2>
        <div class="timeline">
          {experience.map((item) => (
            <article class="timeline-item" id={item.id}>
              <div class="timeline-date">{item.date}</div>
              <div class="timeline-body">
                <h3>{item.title}</h3>
                <p class="timeline-company">
                  {item.companyHref ? (
                    <a href={item.companyHref} target="_blank" rel="noopener">{item.company}</a>
                  ) : (
                    item.company
                  )}
                  {item.subtitle && ` - ${item.subtitle}`}
                </p>
                <ul>
                  {item.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="expertise" class="section section-alt" data-reveal>
      <div class="container">
        <p class="eyebrow">Expertise</p>
        <h2>How I think about talent and systems</h2>
        <div class="three-up-grid">
          {expertise.map((item) => (
            <article class="panel-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" data-reveal>
      <div class="container">
        <p class="eyebrow">What others say</p>
        <h2>Signals from people I have worked with</h2>
        <div class="three-up-grid">
          {testimonials.map((item) => (
            <blockquote class="panel-card quote-card">
              <p>"{item.quote}"</p>
              <footer>
                <strong>{item.author}</strong>
                <span>{item.context}</span>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <section id="education" class="section section-alt" data-reveal>
      <div class="container">
        <p class="eyebrow">Education & Certifications</p>
        <h2>Credentials</h2>
        <div class="two-up-grid">
          {education.map((item) => (
            <article class="panel-card">
              <h3>{item.title}</h3>
              <p class="subtle-label">{item.institution}</p>
              {item.text && <p>{item.text}</p>}
              {item.tags && (
                <div class="tag-list">
                  {item.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section cta-section" data-reveal>
      <div class="container cta-card">
        <p class="eyebrow">Get In Touch</p>
        <h2>Talk talent systems, AI products, or open source</h2>
        <p>
          If the systems thinking here resonates, or you want to compare notes on hiring, prompt governance,
          or agentic workflows, I’m easy to reach.
        </p>
        <div class="button-row">
          <a href={`mailto:${SITE.email}`} class="button button-primary">Email me</a>
          <a href={SITE.linkedin} class="button button-secondary" target="_blank" rel="noopener">Connect on LinkedIn</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
